generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id        Int         @id @default(autoincrement())
  firstName String
  lastName  String
  phoneNo   String
  email     String      @unique
  password  String
  image     String?
  issues    BookIssue[]
}

model Book {
  id       Int         @id @default(autoincrement())
  bookName String
  sem      String
  issues   BookIssue[]
}

model BookIssue {
  id       Int      @id @default(autoincrement())
  s_id     Int
  b_id     Int
  iss_date DateTime
  sub_date DateTime
  book     Book     @relation(fields: [b_id], references: [id])
  student  Student  @relation(fields: [s_id], references: [id])
}
